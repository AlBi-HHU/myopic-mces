// ── Default parameters for MCES Nextflow workflows ──────────────────────────
// Override on the command line: nextflow run nextflow/one_dataset.nf --smiles foo.txt

params {
    // input — one-dataset mode
    smiles = null

    // input — two-dataset mode (smiles_a = main, smiles_b = extra/cross)
    smiles_a = null
    smiles_b = null

    // computation
    threshold = 10
    solver = 'CPLEX_CMD'           // used only when cplex_home is set
    cplex_home = null              // set to CPLEX install dir to enable CPLEX
    choose_bound_dynamically = false
    cpus = 8                       // cores per COMPUTE_BATCH task.
                                    //   Set to your node's total core count to run one batch at
                                    //   a time, each using all cores. Lower values = more batches
                                    //   in parallel, fewer cores each.

    // prepare_input
    batch_size = 224960000

    // db lookup (optional; needs PGHOST/PGDATABASE/... env vars)
    use_db_lookup = false

    // sanity check
    sanity_check = true
    sanity_samples = 10000

    // output
    out = 'results'
}

// ── Container (uncomment and set to your image to enable) ───────────────────
// process.container = 'myopic-mces:latest'
